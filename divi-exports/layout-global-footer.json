  "data": {
    "51005": "<!-- wp:divi/placeholder --><!-- wp:divi/section {\"builderVersion\":0.7,\"module\":{\"meta\":{\"adminLabel\":{\"desktop\":{\"value\":\"Global Footer Section\"}}}}} --><!-- wp:divi/row {\"builderVersion\":0.7,\"module\":{\"meta\":{\"adminLabel\":{\"desktop\":{\"value\":\"Footer Row\"}}},\"advanced\":{\"columnStructure\":{\"desktop\":{\"value\":\"4_4\"}}}}} --><!-- wp:divi/column {\"builderVersion\":0.7,\"module\":{\"meta\":{\"adminLabel\":{\"desktop\":{\"value\":\"Footer Column\"}}},\"advanced\":{\"type\":{\"desktop\":{\"value\":\"4_4\"}}}}} --><!-- wp:divi/text {\"builderVersion\":0.7,\"module\":{\"meta\":{\"adminLabel\":{\"desktop\":{\"value\":\"Footer Content\"}}}},\"content\":{\"innerContent\":{\"desktop\":{\"value\":\"<div style=\\\"width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);background:var(--gcid-dmf-primary, #131b26);color:var(--gcid-dmf-white, #fafafa);padding:4rem 1.5rem 2rem\\\">\\n              <div style=\\\"width:100%;max-width:80rem;margin:0 auto\\\">\\n                <div style=\\\"display:grid;grid-template-columns:repeat(auto-fit, minmax(min(100%, 14rem), 1fr));gap:2.5rem\\\">\\n                  <div>\\n                    <div style=\\\"font-family:var(--gvid-dmf-heading-font);font-size:clamp(1.175rem, calc(1.175rem + 0.24vw), 1.375rem);font-weight:700;margin:0 0 1rem 0\\\">Digital <span style=\\\"display:inline-block;background:linear-gradient(135deg, var(--gcid-dmf-accent, #941213), var(--gcid-dmf-accent-deep, #893637));color:transparent;-webkit-background-clip:text;background-clip:text\\\">MindFlow</span></div>\\n                    <p style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);line-height:1.8;color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent);margin:0;max-width:32rem\\\">A studio offering strategic, modern and effective digital marketing solutions for businesses that want to grow their online presence.</p>\\n                    <div style=\\\"display:flex;flex-wrap:wrap;align-items:center;gap:0.75rem;padding-top:0.125rem\\\">\\n                      <a href=\\\"https://www.facebook.com/digital.mindflow\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\" aria-label=\\\"Facebook\\\" style=\\\"display:inline-flex;align-items:center;justify-content:center;width:2.35rem;height:2.35rem;border:0.0625rem solid color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 14%, transparent);border-radius:62.4375rem;background:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 4%, transparent);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 76%, transparent);text-decoration:none\\\"><span style=\\\"display:inline-flex;align-items:center;justify-content:center;width:1rem;height:1rem\\\"><svg viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.9\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" aria-hidden=\\\"true\\\"><path d=\\\"M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z\\\"></path></svg></span></a><a href=\\\"https://www.instagram.com/digital.mindflow/\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\" aria-label=\\\"Instagram\\\" style=\\\"display:inline-flex;align-items:center;justify-content:center;width:2.35rem;height:2.35rem;border:0.0625rem solid color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 14%, transparent);border-radius:62.4375rem;background:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 4%, transparent);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 76%, transparent);text-decoration:none\\\"><span style=\\\"display:inline-flex;align-items:center;justify-content:center;width:1rem;height:1rem\\\"><svg viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.9\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" aria-hidden=\\\"true\\\"><rect width=\\\"20\\\" height=\\\"20\\\" x=\\\"2\\\" y=\\\"2\\\" rx=\\\"5\\\" ry=\\\"5\\\"></rect><path d=\\\"M16 11.37a4 4 0 1 1-1.37-1.37\\\"></path><line x1=\\\"17.5\\\" x2=\\\"17.51\\\" y1=\\\"6.5\\\" y2=\\\"6.5\\\"></line></svg></span></a><a href=\\\"https://linkedin.com/company/digital-mind-flow\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\" aria-label=\\\"LinkedIn\\\" style=\\\"display:inline-flex;align-items:center;justify-content:center;width:2.35rem;height:2.35rem;border:0.0625rem solid color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 14%, transparent);border-radius:62.4375rem;background:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 4%, transparent);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 76%, transparent);text-decoration:none\\\"><span style=\\\"display:inline-flex;align-items:center;justify-content:center;width:1rem;height:1rem\\\"><svg viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.9\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" aria-hidden=\\\"true\\\"><path d=\\\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\\\"></path><rect width=\\\"4\\\" height=\\\"12\\\" x=\\\"2\\\" y=\\\"9\\\"></rect><circle cx=\\\"4\\\" cy=\\\"4\\\" r=\\\"2\\\"></circle></svg></span></a>\\n                    </div>\\n                  </div>\\n                  <div>\\n                    <h4 style=\\\"font-family:var(--gvid-dmf-heading-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);font-weight:600;color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 80%, transparent);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem 0\\\">Quick Links</h4>\\n                    <div style=\\\"display:flex;flex-direction:column;gap:0.625rem\\\">\\n                      <a href=\\\"/#about\\\" style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent);text-decoration:none\\\">About</a><a href=\\\"/#services\\\" style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent);text-decoration:none\\\">Services</a><a href=\\\"/#process\\\" style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent);text-decoration:none\\\">Process</a><a href=\\\"/#contact\\\" style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent);text-decoration:none\\\">Contact</a>\\n                    </div>\\n                  </div>\\n                  <div>\\n                    <h4 style=\\\"font-family:var(--gvid-dmf-heading-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);font-weight:600;color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 80%, transparent);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem 0\\\">Contact</h4>\\n                    <div style=\\\"display:flex;flex-direction:column;gap:0.75rem\\\">\\n                      <a href=\\\"mailto:info@mindflowdigital.com\\\" style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent);text-decoration:none\\\">info@mindflowdigital.com</a>\\n                      <a href=\\\"tel:+35799882116\\\" style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent);text-decoration:none\\\">+357 99 882116</a>\\n                      <div style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.8312rem, calc(0.8312rem + 0.18vw), 0.9275rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 60%, transparent)\\\">Paphos, Cyprus</div>\\n                    </div>\\n                  </div>\\n                </div>\\n                <div style=\\\"margin-top:3rem;padding:1.5rem 0 0;border-top:0.0625rem solid color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 10%, transparent);display:flex;justify-content:space-between;gap:0.75rem;flex-wrap:wrap\\\">\\n                  <span style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.705rem, calc(0.705rem + 0.12vw), 0.765rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 40%, transparent)\\\">&copy; 2026 Digital MindFlow. All rights reserved.</span>\\n                  <span style=\\\"font-family:var(--gvid-dmf-body-font);font-size:clamp(0.705rem, calc(0.705rem + 0.12vw), 0.765rem);color:color-mix(in srgb, var(--gcid-dmf-white, #fafafa) 40%, transparent)\\\">Marketing Services &middot; Paphos, Cyprus</span>\\n                </div>\\n              </div>\\n            </div>\"}}}} /--><!-- /wp:divi/column --><!-- /wp:divi/row --><!-- /wp:divi/section --><!-- /wp:divi/placeholder -->"
